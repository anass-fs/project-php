{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "env": {
      "COMPOSER_NO_SCRIPTS": "1",
      "APP_ENV": "prod"
    }
  },
  "deploy": {
    "startCommand": "php bin/console cache:clear && php -S 0.0.0.0:$PORT -t public",
    "restartPolicyCondition": "ON_FAILURE"
  }
}
