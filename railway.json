{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "composer install --no-dev --optimize-autoloader --no-scripts"
  },
  "deploy": {
    "startCommand": "php bin/console cache:clear && php -S 0.0.0.0:$PORT -t public",
    "restartPolicyCondition": "ON_FAILURE"
  }
}
