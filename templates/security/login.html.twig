{% extends 'base.html.twig' %}

{% block title %}Connexion | SantéPlus{% endblock %}

{% block body %}
    <section id="login-section" class="section">
        <h1>Connexion</h1>
        <form id="login-form" action="{{ path('app_login') }}" method="POST">
            {% if error %}
                <div id="login-message" style="color:red; margin-top:10px;">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}
            
            <div class="form-group">
                <label for="username">Nom d'utilisateur :</label>
                <input type="text" id="username" name="_username" value="{{ last_username }}" placeholder="Votre nom d'utilisateur" required />
            </div>
            
            <div class="form-group">
                <label for="password">Mot de passe :</label>
                <input type="password" id="password" name="_password" placeholder="Votre mot de passe" required />
            </div>
            
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            
            <button type="submit" class="submit-button">Se connecter</button>
        </form>
        <p id="login-message" style="color:red; margin-top:10px;"></p>
    </section>
{% endblock %}

