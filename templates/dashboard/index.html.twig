{% extends 'base.html.twig' %}

{% block title %}Tableau de bord | SantéPlus{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row">
        <div class="col-md-12 mb-4">
            <h1 class="h2">Bienvenue, {{ patient.prenom }} {{ patient.nom }}</h1>
            <p class="text-muted">Gérez vos rendez-vous et votre santé en toute simplicité.</p>
        </div>
    </div>

    <div class="row">
        <!-- Statistiques -->
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-primary">Mes rendez-vous</h5>
                    <p class="display-4 fw-bold">{{ nombreRendezVous }}</p>
                    <p class="card-text">Total de rendez-vous enregistrés.</p>
                </div>
            </div>
        </div>

        <!-- Prochain Rendez-vous -->
        <div class="col-md-8 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <h5 class="card-title text-success">Prochain rendez-vous</h5>
                    {% if prochainRendezVous %}
                        <div class="d-flex align-items-center mt-3">
                            <div class="me-4">
                                <p class="mb-0 text-muted small">Date</p>
                                <p class="h5 mb-0">{{ prochainRendezVous.date|date('d/m/Y') }}</p>
                            </div>
                            <div class="me-4">
                                <p class="mb-0 text-muted small">Heure</p>
                                <p class="h5 mb-0">{{ prochainRendezVous.heure|date('H:i') }}</p>
                            </div>
                            <div>
                                <p class="mb-0 text-muted small">Médecin</p>
                                <p class="h5 mb-0">Dr. {{ prochainRendezVous.medecin.nom }}</p>
                            </div>
                        </div>
                    {% else %}
                        <p class="mt-3">Vous n'avez aucun rendez-vous à venir.</p>
                        <a href="{{ path('app_rendezvous_new') }}" class="btn btn-outline-success btn-sm">Prendre un rendez-vous</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Liste des rendez-vous -->
        <div class="col-md-12 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title mb-4">Historique de vos rendez-vous</h5>
                    {% if allRendezVous is not empty %}
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Heure</th>
                                        <th>Médecin</th>
                                        <th>Spécialité</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for rdv in allRendezVous %}
                                        <tr>
                                            <td>{{ rdv.date|date('d/m/Y') }}</td>
                                            <td>{{ rdv.heure|date('H:i') }}</td>
                                            <td>Dr. {{ rdv.medecin.nom }}</td>
                                            <td>{{ rdv.medecin.specialite }}</td>
                                            <td>
                                                {% if rdv.date|date('Y-m-d') < "now"|date('Y-m-d') %}
                                                    <span class="badge bg-secondary">Terminé</span>
                                                {% else %}
                                                    <span class="badge bg-success">Confirmé</span>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <p class="text-center py-4 text-muted">Vous n'avez pas encore pris de rendez-vous.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
